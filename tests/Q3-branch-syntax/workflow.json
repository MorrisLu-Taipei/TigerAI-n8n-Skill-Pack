{
  "name": "Q3-Order-Risk-Routing-BranchDSL",
  "nodes": [
    {
      "id": "sticky-user-1",
      "name": "Layer1 使用者需求 (DSL v1.1 @branch)",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        0,
        -360
      ],
      "parameters": {
        "color": 4,
        "width": 800,
        "height": 360,
        "content": "## 需求：電商訂單 AI 風險分流\n\n@flow: 收訂單 → AI 風險評分 → 依風險高/中/低三路處理\n@trigger: webhook POST /order\n@input: { order_id, customer_email, amount, ip, items[] }\n\n@step: AI 風險評分（OpenAI gpt-4o-mini）→ 回 {score: 0-100, reason: string}\n\n@branch: high when score > 70\n  - jira project=FRAUD create issue summary \"High-risk order {order_id}\"\n  - slack #fraud-alert \"⚠️ High-risk order {order_id} score={score}\"\n\n@branch: medium when score >= 30 and score <= 70\n  - postgres insert review_queue (order_id, score, reason, payload)\n\n@branch: low when score < 30\n  - postgres insert orders (order_id, customer_email, amount, risk_score)\n\n@output: webhook 回 { order_id, status: <branch_name> }\n@on-error: slack #ops-alert\n@assume: Postgres 表 review_queue / orders 已存在"
      }
    },
    {
