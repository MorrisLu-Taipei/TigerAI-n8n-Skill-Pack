      "name": "WebhookOrder",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        0,
        100
      ],
      "parameters": {
        "httpMethod": "POST",
        "path": "order",
        "responseMode": "responseNode",
        "options": {}
      },
      "notes": "@trigger",
      "webhookId": "c79fad99-2faf-4514-ba8b-658a47b96dba"
    },
